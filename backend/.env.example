# Security Configuration
SECRET_KEY=super-secret-key-change-in-production-12345

# Database Configuration
# Use SQLite locally by default:
DATABASE_URL=sqlite+aiosqlite:///./verifyai.db
# For PostgreSQL in production, change to:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/verifyai

# AI Chatbot Configuration
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# Google Sign-In via Firebase
# From Firebase Console Project Settings:
FIREBASE_PROJECT_ID=

# CORS Allowed Origins (comma separated list for production, e.g. https://your-app.vercel.app)
CORS_ORIGINS=
